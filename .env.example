# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# Get your free Groq API key at: console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Your live portfolio URL — the AI reads this directly
PORTFOLIO_URL=https://your-portfolio-url.com

# Your name — used in the assistant's responses
OWNER_NAME=Your Name

# Your email — the assistant directs unknown questions here
OWNER_EMAIL=your@email.com
